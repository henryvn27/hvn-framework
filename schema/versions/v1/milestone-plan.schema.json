{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://orca-hvn.dev/schema/v1/milestone-plan.schema.json",
  "title": "ORCA-HVN Milestone Plan v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_family", "schema_version", "title", "phases", "verification_gates"],
  "properties": {
    "schema_family": { "const": "milestone_plan" },
    "schema_version": { "const": "1.0.0" },
    "title": { "type": "string" },
    "linked_spec": { "type": "string" },
    "phases": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "objective"],
        "properties": {
          "name": { "type": "string" },
          "objective": { "type": "string" },
          "artifacts": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "verification_gates": { "type": "array", "items": { "type": "string" } },
    "approval_expectations": { "type": "array", "items": { "type": "string" } }
  }
}
